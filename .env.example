PORT=3000

# Database (use either DATABASE_URL or individual DB_* vars)
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=12345678
DB_NAME=postgres
DB_SSL=false

# Auth secrets
JWT_KEY=change-me
JWT_SUPERUSER_KEY=change-me
JWT_ADMIN_KEY=change-me
JWT_CTO_KEY=change-me
SUPERUSER_SECRET_KEY=change-me

# Google Drive backup auth (OAuth recommended)
GOOGLE_DRIVE_AUTH_MODE=oauth
GOOGLE_DRIVE_FOLDER_ID=1_OB-Y83OFfCxw7AKpoX-wxucXYgc5YlB
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=
GOOGLE_DRIVE_REDIRECT_URI=http://localhost
GOOGLE_DRIVE_REFRESH_TOKEN=

# Optional file-path based fallback (usually not needed in production)
# GOOGLE_DRIVE_OAUTH_CLIENT_SECRET_PATH=./key/client_secret_xxx.json
# GOOGLE_DRIVE_OAUTH_TOKEN_PATH=./key/google_oauth_token.json
# GOOGLE_DRIVE_SERVICE_ACCOUNT_KEY_PATH=./key/unipos-490308-f0139a155b46.json

# Google Apps Script endpoint for Sheets backup/restore proxy
GOOGLE_APPS_SCRIPT_URL=https://script.google.com/macros/s/your-script-id/exec
